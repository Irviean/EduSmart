<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="40dp">

        <!-- Label kategori -->
        <TextView
            android:id="@+id/tvHasilKategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="Quiz Coding"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Card nilai utama -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNilai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <TextView
                    android:id="@+id/tvHasilEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎉"
                    android:textSize="52sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvHasilJudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Luar Biasa!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="16dp" />

                <!-- Nilai besar -->
                <TextView
                    android:id="@+id/tvNilai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 100"
                    android:textColor="#9E9E9E"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvBenarSalah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 benar dari 5 soal"
                    android:textColor="#616161"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Garis pemisah -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <!-- Feedback teks -->
                <TextView
                    android:id="@+id/tvFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Kamu menguasai materi ini dengan sangat baik!"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card rekap semua nilai -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tvRekap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="📊 Rekap Nilai Kamu:\n  • Coding  : -\n  • UI/UX   : -\n  • Design  : -"
                android:textColor="#424242"
                android:textSize="14sp"
                android:lineSpacingExtra="6dp"
                android:fontFamily="monospace" />
        </androidx.cardview.widget.CardView>

        <!-- Tombol Ulangi -->
        <Button
            android:id="@+id/btnUlangQuiz"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔁  Ulangi Quiz"
            android:backgroundTint="#007BFF"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <!-- Tombol Ke Dashboard -->
        <Button
            android:id="@+id/btnKeHome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🏠  Kembali ke Home"
            android:backgroundTint="#E3F2FD"
            android:textColor="#007BFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
