<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center_horizontal">

        <!-- Header biru -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Buat Akun Baru"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#007BFF"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar dan mulai belajar sekarang!"
            android:textColor="#757575"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Nama Lengkap -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama Lengkap"
            android:textColor="#212121"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etNama"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Nama lengkap kamu"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="#212121"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#212121"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etEmailReg"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="contoh@email.com"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="#212121"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#212121"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etPasswordReg"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Minimal 6 karakter"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="#212121"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Konfirmasi Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Konfirmasi Password"
            android:textColor="#212121"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etKonfirmasi"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Ulangi password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="#212121"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Tombol Daftar -->
        <Button
            android:id="@+id/btnDaftar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Daftar Sekarang"
            android:backgroundTint="#007BFF"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

        <!-- Link ke Login -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sudah punya akun? "
                android:textColor="#757575"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvKeLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk di sini"
                android:textColor="#007BFF"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
